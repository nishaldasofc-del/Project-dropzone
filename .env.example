# Copy this to .env and fill in your values

# Server
NODE_ENV=production
PORT=3000

# MongoDB (Docker Compose)
MONGO_ROOT_USER=admin
MONGO_ROOT_PASS=CHANGE_THIS_SECURE_PASSWORD

# JWT - MUST be a long random string in production
JWT_SECRET=CHANGE_THIS_TO_A_VERY_LONG_RANDOM_SECRET_STRING_64_CHARS_MINIMUM

# CORS - set to your domain
CORS_ORIGIN=https://yourdomain.com

# Logging
LOG_LEVEL=info
